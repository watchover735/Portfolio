# EmailJS credentials — create a free account at https://www.emailjs.com/
# Copy this file to `.env` and fill in your real values, then restart `npm run dev`.
# Until these are set, the contact form falls back to a mailto: link automatically.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# The email address shown on the site + used as the mailto fallback target.
VITE_CONTACT_EMAIL=your@email.com
